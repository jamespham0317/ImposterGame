# Backend Configuration
# ====================

# For local development, use:
#   HOST=localhost
#   PORT=8765

# For AWS/production deployment with EC2, use:
#   HOST=0.0.0.0        (server listens on all interfaces)
#   PORT=8765
# Then configure VITE_BACKEND_URL to point to your EC2 IP

HOST=0.0.0.0
PORT=8765

# Engine API Configuration
CHEATCODE_ENGINE_API_KEY=your_api_key_here
ALLOW_LOCAL_TEST_EXECUTION=true

# Game Configuration
MIN_PLAYERS_TO_START=1
MIN_PLAYERS_TO_CONTINUE=1

# WebSocket Message Limits
MAX_WS_MESSAGE_BYTES=65536
MAX_PLAYER_ID_LENGTH=24
MAX_CHAT_MESSAGE_LENGTH=600
MAX_CODE_LENGTH=30000

# Health Check Endpoint
HEALTH_ENDPOINT_ENABLED=false

# Frontend Configuration
# =====================

# For local development (both backend and frontend running locally):
#   VITE_BACKEND_URL=ws://localhost:8765

# For AWS/production deployment (frontend on another domain, backend on EC2):
#   VITE_BACKEND_URL=ws://YOUR_EC2_IP:8765
#   OR if using a domain:
#   VITE_BACKEND_URL=wss://your-domain.com:8765  (for HTTPS)

VITE_BACKEND_URL=ws://localhost:8765

# Minimum players needed to start a game
VITE_MIN_PLAYERS_TO_START=1
